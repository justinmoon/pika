#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

if [ "${1:-}" = "--with-media" ]; then
  exec cargo test -p pikahut --test integration_deterministic cli_smoke_media_local -- --ignored --nocapture
fi

exec cargo test -p pikahut --test integration_deterministic cli_smoke_local -- --ignored --nocapture
