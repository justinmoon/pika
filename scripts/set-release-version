#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
VERSION_FILE="$ROOT/VERSION"
IOS_PROJECT_YML="$ROOT/ios/project.yml"

usage() {
  cat <<'EOF'
Usage: ./scripts/set-release-version <version>

Sets the shared release version and syncs dependent manifests.

Updates:
- VERSION
- ios/project.yml (MARKETING_VERSION)
- cli/Cargo.toml
- pikachat-openclaw/openclaw/extensions/pikachat-openclaw/package.json
- Cargo.lock (via `cargo check -p pikachat`)
EOF
}

if [ "$#" -ne 1 ]; then
  usage >&2
  exit 2
fi

VERSION="$1"
if [[ ! "$VERSION" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
  echo "error: version must be x.y.z (got: $VERSION)" >&2
  exit 1
fi

printf '%s\n' "$VERSION" > "$VERSION_FILE"

awk -v version="$VERSION" '
  BEGIN {
    updated = 0
  }
  !updated && /^[[:space:]]*MARKETING_VERSION:/ {
    match($0, /^[[:space:]]*/)
    indent = substr($0, RSTART, RLENGTH)
    print indent "MARKETING_VERSION: " version
    updated = 1
    next
  }
  {
    print
  }
  END {
    if (!updated) {
      exit 1
    }
  }
' "$IOS_PROJECT_YML" > "$IOS_PROJECT_YML.tmp" || {
  rm -f "$IOS_PROJECT_YML.tmp"
  echo "error: failed to update MARKETING_VERSION in $IOS_PROJECT_YML" >&2
  exit 1
}
mv "$IOS_PROJECT_YML.tmp" "$IOS_PROJECT_YML"

if ! grep -q "MARKETING_VERSION: ${VERSION}" "$IOS_PROJECT_YML"; then
  echo "error: MARKETING_VERSION verification failed for $IOS_PROJECT_YML" >&2
  exit 1
fi

"$ROOT/scripts/sync-pikachat-version" "$VERSION"

echo "ok: synced release version $VERSION"
