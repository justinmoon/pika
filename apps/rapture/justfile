set shell := ["bash", "-c"]

default:
  @just --list

# Run root rmp-cli against apps/rapture.
rmp *ARGS:
  cargo run --manifest-path ../../Cargo.toml -p rmp-cli -- --root . {{ARGS}}

doctor:
  just rmp doctor

bindings TARGET="all":
  just rmp bindings {{TARGET}}

run-ios:
  just bindings swift
  just rmp run ios

run-android *ARGS:
  ../../tools/android-emulator-ensure
  just bindings kotlin
  just rmp run android {{ARGS}}

ui-test-ios:
  just run-ios

ui-test-android:
  just run-android

bootstrap-smoke:
  cargo test --manifest-path rust/Cargo.toml --test bootstrap_smoke

rust-tests:
  cargo test --manifest-path rust/Cargo.toml --lib --test control_ops --test permission_matrix --test app_flows --test reconcile_membership --test chat_ops --test voice_ops --test channel_groups

ui-e2e-local:
  RAPTURE_E2E_LOCAL=1 cargo test --manifest-path rust/Cargo.toml --test e2e_local_relay -- --ignored --nocapture

voice-e2e-local:
  RAPTURE_E2E_MOQ=1 cargo test --manifest-path rust/Cargo.toml --test e2e_local_moq_voice -- --ignored --nocapture

pre-merge:
  just bootstrap-smoke
  just rust-tests
  cargo check --manifest-path Cargo.toml
  @echo "pre-merge (rapture) complete"
